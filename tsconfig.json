{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": false,
    "target": "es6",
    "declarationDir": "dist",
    "baseUrl": "./src",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": false,
  },
  "include": [
    "src/**/*"
  ]
}
